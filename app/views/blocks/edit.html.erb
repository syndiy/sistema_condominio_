<div class="container-crud">
  <div class="card-standard">
    
    <div class="login-header" style="text-align: center; margin-bottom: 40px;">
      <h1 class="brand-name">Editar <span class="brand-bold">Bloco</span></h1>
      <p class="login-subtitle">Atualize as informações da torre ou bloco selecionado.</p>
    </div>

    <%= form_with(model: @block, local: true) do |f| %>
      
      <div class="form-group-login">
        <%= f.label :identification, "IDENTIFICAÇÃO DO BLOCO", class: "form-label-login" %>
        <%= f.text_field :identification, class: "form-input-login" %>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group-login">
          <%= f.label :floors_count, "QUANTIDADE DE ANDARES", class: "form-label-login" %>
          <%= f.number_field :floors_count, class: "form-input-login" %>
        </div>

        <div class="form-group-login">
          <%= f.label :apartments_per_floor, "APTOS POR ANDAR", class: "form-label-login" %>
          <%= f.number_field :apartments_per_floor, class: "form-input-login" %>
        </div>
      </div>

      <div class="actions-container">
        <%= f.submit "Salvar Alterações", class: "btn-pro-size btn-edit-pro" %>
        <%= link_to "Cancelar", block_path(@block), class: "btn-pro-size btn-delete-pro" %>
      </div>

    <% end %>
  </div>
</div>