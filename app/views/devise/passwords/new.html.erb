<div class="login-split-container">
  <div class="login-form-col">
    <div class="login-box">
      <div class="login-header">
        <h1 class="brand-name">Condomínio<span class="brand-bold">Pro</span></h1>
        <p class="login-subtitle">Recupere seu acesso ao sistema.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "standard-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-group">
          <%= f.label :email, "E-MAIL CADASTRADO" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com.br", class: "form-input" %>
        </div>

        <div class="login-actions">
          <%= f.submit "Enviar instruções de senha", class: "btn-login-pro" %>
        </div>
      <% end %>

      <div class="login-footer">
        <p class="text-muted-sm">Lembrou a senha? <%= link_to "Fazer Login", new_session_path(resource_name), class: "login-link" %></p>
      </div>
    </div>
  </div>

  <div class="login-visual-col">
    <div class="visual-content">
      <h2 class="visual-title">"Segurança e agilidade na palma da sua mão."</h2>
      <p class="visual-description">Recupere sua senha de forma rápida e segura para voltar a gerenciar seu condomínio.</p>
    </div>
  </div>
</div>