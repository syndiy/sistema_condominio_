<div class="login-split-container">
  <div class="login-form-col">
    <div class="login-box">
      <div class="login-header">
        <h1 class="brand-name">Condomínio<span class="brand-bold">Pro</span></h1>
        <p class="login-subtitle">Crie sua conta para começar.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "standard-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-group">
          <%= f.label :email, "E-MAIL CORPORATIVO" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com.br", class: "form-input" %>
        </div>

        <div class="form-group">
          <%= f.label :password, "SENHA" %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Mínimo 6 caracteres", class: "form-input" %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "CONFIRME SUA SENHA" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repita a senha", class: "form-input" %>
        </div>

        <div class="login-actions">
          <%= f.submit "Solicitar Cadastro", class: "btn-login-pro" %>
        </div>
      <% end %>

      <div class="login-footer">
        <p class="text-muted-sm">Já possui uma conta? <%= link_to "Entrar no Sistema", new_session_path(resource_name), class: "login-link" %></p>
      </div>
    </div>
  </div>

  <div class="login-visual-col">
    <div class="visual-content">
      <h2 class="visual-title">"A gestão eficiente do seu condomínio começa aqui."</h2>
      <p class="visual-description">Centralize chamados, usuários, blocos e unidades em uma plataforma robusta e intuitiva.</p>
    </div>
  </div>
</div>