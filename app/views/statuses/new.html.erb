<div class="page-shell">
  <div class="card-base" style="max-width: 400px; margin: 0 auto;">
    <h1 style="margin-bottom: 20px;">🆕 Novo Status</h1>

    <%= form_with(model: @status) do |f| %>
      <div class="form-group" style="margin-bottom: 20px;">
        <%= f.label :name, "Nome do Status (Ex: Em Análise)", class: "form-label" %>
        <%= f.text_field :name, class: "form-input", placeholder: "Digite o status..." %>
      </div>

      <div style="display: flex; gap: 15px; align-items: center;">
        <%= f.submit "Salvar Status", class: "btn btn-primary", style: "flex: 1;" %>
        <%= link_to "Cancelar", statuses_path, class: "link-muted" %>
      </div>
    <% end %>
  </div>
</div>