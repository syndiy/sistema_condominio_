<div class="container-crud">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
      <h1 style="color: #13505B; font-weight: 800;">
        <%= current_user.morador? ? "Meus Chamados" : "Gerenciar Chamados" %>
      </h1>
      
      <p style="color: #64748b;">
        <%= current_user.morador? ? "Acompanhe suas solicitações." : "Painel de controle e gestão de chamados." %>
      </p>
    </div>

    <%# BOTÃO DE NOVO CHAMADO %>
    <% if current_user.morador? || current_user.admin? %>
      <%= link_to "+ Abrir Novo Chamado", new_ticket_path, class: "btn-pro-size btn-edit-pro", style: "width: 220px !important;" %>
    <% end %>

    <%# ESPECIALIDADES DO COLABORADOR %>
    <% if current_user.colaborador? %>
  <div style="background: #eef2ff; padding: 15px; border-radius: 10px; border: 1px solid #e0e7ff;">
    <h4 style="color: #4338ca; margin: 0; font-size: 0.8rem; text-transform: uppercase;">My Specialties:</h4>
    <div style="display: flex; gap: 5px; margin-top: 8px;">
      <% if current_user.assigned_categories.any? %>
        <% current_user.assigned_categories.each do |cat| %>
          <span style="background: #4338ca; color: white; padding: 2px 10px; border-radius: 20px; font-size: 0.75rem;">
            <%= cat.title %>
          </span>
        <% end %>
      <% else %>
        <span style="color: #64748b; font-size: 0.8rem;">No categories assigned.</span>
      <% end %>
    </div>
  </div>
<% end %>
  </div>

<div class="card-table">
  <table class="data-table">
    <thead>
      <tr>
        <th style="width: 25%;">ASSUNTO</th>
        <th style="width: 10%;">APTO</th>
        <th style="width: 25%;">SOLICITANTE</th>
        <th style="width: 15%;">SITUAÇÃO</th>
        <th style="width: 25%; text-align: right; padding-right: 25px;">AÇÕES</th>
      </tr>
    </thead>
    <tbody>
      <% @tickets.each do |ticket| %>
        <tr>
          <td>
            <div style="display: flex; flex-direction: column;">
              <strong style="color: #13505B; font-size: 0.95rem; line-height: 1.2;"><%= ticket.title %></strong>
              
            
              <% if ticket.ticket_type.present? %>  
                <span style="color: #64748b;font-size: 0.75rem; font-weight: 500; text-transform: uppercase; margin-top: 2px;">
                   <%= ticket.ticket_type.title %>
                </span>
              <% end %>
              
              <span style="font-size: 0.75rem; color: #64748b; margin-top: 2px;"><%= ticket.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
            </div>
          </td>

          <td>
            <span style="font-weight: 700; color: #1e293b;"><%= ticket.unit&.number %></span>
          </td>

          <td>
            <div style="font-size: 0.85rem;">
              <div style="font-weight: 600; color: #1e293b;"><%= ticket.user&.name %></div>
              <div style="color: #64748b;"><%= ticket.user&.email %></div>
            </div>
          </td>

          <td>
            <% status_nome = ticket.status&.name&.downcase || "" %>
            <% status_class = case 
               when status_nome.include?('concluido') || status_nome.include?('concluído') then 'status-badge morador'
               when status_nome.include?('aberto') then 'status-badge admin'
               else 'status-badge colaborador'
               end %>
            <span class="<%= status_class %>">
              <%= ticket.status&.name&.upcase %>
            </span>
          </td>

          <td>
            <div style="display: inline-flex; justify-content: flex-end; gap: 8px; width: 100%; white-space: nowrap;">
              <%= link_to "Detalhes", ticket, class: "btn-action-pill btn-details-pill" %>
          
              <% if !current_user.morador? %>
                <%= link_to "Mudar Status", edit_ticket_path(ticket), class: "btn-action-pill btn-details-pill" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>