<div class="ticket-card" style="border: 1px solid #ccc; padding: 20px; border-radius: 10px; background: #fff;">
  <%# Note o @ antes de ticket %>
  <h2><%= @ticket.title %></h2>
  <hr>
  
  <p><strong>Status:</strong> 
    <span style="padding: 5px 10px; border-radius: 5px; background: #e0f0ff; color: #007bff;">
      <%= @ticket.status.name %>
    </span>
  </p>

  <p><strong>Local: <%= @ticket.unit.number %> (<%= @ticket.unit.block.identification %>)</p>
  
  <p><strong>Tipo de Problema:</strong> <%= @ticket.ticket_type.title %></p>
  
  <p><strong>Descrição:</strong><br>
    <%= @ticket.description %>
  </p>

  <p><strong>Aberto em:</strong> <%= @ticket.created_at.strftime("%d/%m/%Y às %H:%M") %></p>

  <% if @ticket.finished_at.present? %>
    <p style="color: green;"><strong>Resolvido em:</strong> <%= @ticket.finished_at.strftime("%d/%m/%Y às %H:%M") %></p>
  <% else %>
   <%# Troquei duration_hours por sla_hours %>
<p style="color: orange;">
  <strong>Prazo Estimado:</strong> 
  <%= (@ticket.created_at + @ticket.ticket_type.sla_hours.hours).strftime("%d/%m/%Y %H:%M") %>
</p>
  <% end %>
</div>

<div style="margin-top: 20px;">
  <%= link_to "Editar Chamado", edit_ticket_path(@ticket) %> |
  <%= link_to "Voltar para Meus Chamados", tickets_path %>
</div>

<hr>
<h3>Histórico de Interações</h3>

<div id="comments" style="margin-bottom: 20px;">
  <% if @ticket.comments.any? %>
    <% @ticket.comments.each do |comment| %>
      <div style="background: #f1f1f1; padding: 10px; border-radius: 5px; margin-bottom: 10px;">
        <strong><%= comment.user.email %></strong> (<%= comment.created_at.strftime("%d/%m %H:%M") %>):
        <p><%= comment.content %></p>
      </div>
    <% end %>
  <% else %>
    <p>Nenhuma mensagem ainda.</p>
  <% end %>
</div>

<h4>Nova Mensagem</h4>
<%= form_with(model: [ @ticket, @ticket.comments.build ]) do |f| %>
  <div>
  
    <%= f.text_area :content, placeholder: "Escreva uma atualização...", style: "width: 100%; height: 80px;" %>
  </div>
  <%= f.submit "Enviar Mensagem", style: "margin-top: 10px;" %>
<% end %>