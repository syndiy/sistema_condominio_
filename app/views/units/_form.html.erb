<%= form_with(model: unit) do |form| %>
  <% if unit.errors.any? %>
    <div style="color: red;">
      <h2><%= pluralize(unit.errors.count, "erro") %> impediram de salvar:</h2>
      <ul>
        <% unit.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :number, "Número da Unidade (Ex: A101)" %>
    <%= form.text_field :number %>
  </div>

  <div>
    <%= form.label :floor, "Andar" %>
    <%= form.text_field :floor %> 
  </div>

  <div>
    <%= form.label :block_id, "Bloco Correspondente" %>
    <%# Aqui mostramos o nome e o total de aptos para não ficar confuso %>
    <%= form.collection_select :block_id, Block.all, :id, 
        ->(b) { "#{b.identification} (#{b.floors_count * b.apartments_per_floor} aptos no total)" }, 
        { prompt: "Selecione o Bloco" } %>
  </div>

  <div style="margin-top: 20px;">
    <%= form.submit "Salvar Unidade", style: "background: #28a745; color: white; padding: 10px; border: none; cursor: pointer;" %>
  </div>
<% end %>