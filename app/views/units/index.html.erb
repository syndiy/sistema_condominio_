<h1 style="margin-bottom: 20px;">Unidades (Apartamentos)</h1>

<%= form_with url: units_path, method: :get, local: true, style: "margin-bottom: 20px;" do |f| %>
  <%= f.text_field :query, placeholder: "Buscar por número ou bloco...", 
      value: params[:query], style: "padding: 8px; width: 300px;" %>
  <%= f.submit "Pesquisar", style: "padding: 8px 15px; cursor: pointer;" %>
  <%= link_to "Limpar", units_path if params[:query].present? %>
<% end %>

<table style="width: 100%; border-collapse: collapse;">
  <thead>
    <tr style="background-color: #333; color: white; text-align: left;">
      <th style="padding: 12px;">Etiqueta</th>
      <th style="padding: 12px;">Bloco</th>
      <th style="padding: 12px;">Andar</th>
      <th style="padding: 12px;">Morador</th> <th style="padding: 12px;">Ações</th>
    </tr>
  </thead>
  <tbody>
    <% 
      current_block = nil
      row_color = "#f2f2f2" 
    %>
    
    <% @units.each do |unit| %>
      <% 
        if unit.block_id != current_block
          current_block = unit.block_id
          row_color = (row_color == "#ffffff" ? "#f2f2f2" : "#ffffff")
        end 
      %>

      <tr style="background-color: <%= row_color %>; border-bottom: 1px solid #ddd;">
        <td style="padding: 10px;"><strong><%= unit.number %></strong></td>
        <td style="padding: 10px;"><%= unit.block.identification %></td>
        <td style="padding: 10px;"><%= unit.floor %></td>
        
  <td style="padding: 10px;">
  <% if unit.users.any? %>
    <%# Exibe o e-mail dos moradores vinculados %>
    <%= unit.users.map(&:email).join(", ") %>
  <% else %>
    <span style="color: #999;">--</span>
  <% end %>
</td>
        <td style="padding: 10px;">
          <%= link_to "Ver", unit %> |
          <%= link_to "Editar", edit_unit_path(unit) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div style="margin-top: 20px;">
  <%= link_to "Nova Unidade", new_unit_path, style: "background: #28a745; color: white; padding: 10px 15px; border-radius: 5px; text-decoration: none;" %>
</div>