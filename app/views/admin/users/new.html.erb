<div class="page-shell">
  <div class="card-base" style="max-width: 500px; margin: 0 auto;">
    <h1 style="margin-bottom: 25px;">👤 Cadastrar Novo Usuário</h1>

    <%= form_with(model: [:admin, @user]) do |f| %>
      <div class="form-group" style="margin-bottom: 15px;">
        <%= f.label :name, "Nome Completo", class: "form-label" %>
        <%= f.text_field :name, class: "form-input", placeholder: "Ex: Eduarda Keila Silva" %>
      </div>

      <div class="form-group" style="margin-bottom: 15px;">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, class: "form-input", placeholder: "email@exemplo.com" %>
      </div>

      <div class="form-group" style="margin-bottom: 25px;">
        <%= f.label :role, "Tipo de Usuário", class: "form-label" %>
        <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "form-input" %>
      </div>

      <%# Localize a parte dos botões no seu new.html.erb e troque por isso %>
<div style="display: flex; gap: 15px; align-items: center; margin-top: 10px;">
  <%= f.submit "Cadastrar Usuário", class: "btn btn-primary", style: "flex: 1;" %>
  <%= link_to "Cancelar", admin_users_path, style: "text-decoration: none; color: #64748b; font-weight: 600; font-size: 14px;" %>
</div>
    <% end %>
  </div>
</div>