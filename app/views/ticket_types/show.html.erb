<div class="container-crud">
  <div class="card-standard">
    
    <%# HEADER CENTRALIZADO %>
    <div class="login-header" style="text-align: center; margin-bottom: 40px;">
    
      <h1 class="brand-name">Detalhes da <span class="brand-bold">Categoria</span></h1>
      <p class="login-subtitle">Configurações de tempo de resposta (SLA).</p>
    </div>

    <%# GRID DE INFORMAÇÕES %>
    <div class="info-section-pro" style="margin-bottom: 40px;">
      <h3 style="font-size: 0.85rem; font-weight: 800; color: #13505B; margin-bottom: 25px; text-transform: uppercase; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px;">
        Configuração de SLA
      </h3>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <div>
          <span class="form-label-login" style="font-size: 0.7rem;">CATEGORIA / TIPO</span>
          <p style="font-size: 1.2rem; font-weight: 700; color: #1e293b; margin: 5px 0;">
            <%= @ticket_type.title %>
          </p>
        </div>
        <div>
          <span class="form-label-login" style="font-size: 0.7rem;">PRAZO ESTIMADO (SLA)</span>
          <p style="font-size: 1.2rem; font-weight: 700; color: #119DA4; margin: 5px 0;">
            <%= @ticket_type.sla_hours %> horas
          </p>
        </div>
      </div>
    </div>

    <%# BOTÕES PADRONIZADOS %>
    <div class="actions-container">
      <%= link_to "Editar Categoria", edit_ticket_type_path(@ticket_type), class: "btn-pro-size btn-edit-pro" %>
      
      <%= button_to "Excluir Categoria", @ticket_type, method: :delete, 
          form: { data: { turbo_confirm: "Apagar esta categoria de SLA?" } }, 
          class: "btn-pro-size btn-delete-pro" %>

      <%= link_to "Voltar", ticket_types_path, class: "btn-pro-size btn-secondary", style: "background-color: transparent !important; border: none !important; width: auto !important; color: #64748b !important; text-decoration: underline !important;" %>
    </div>

  </div>
</div>