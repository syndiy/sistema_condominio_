<div class="container-crud">
  <div class="header-section" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
      <h1 class="brand-name">Configurações de <span class="brand-bold">SLA</span></h1>
      <p class="login-subtitle" style="margin-top: 5px;">Prazos de resolução por categoria.</p>
    </div>
<%= link_to "+ Nova Categoria", new_ticket_type_path, class: "btn-pro-size btn-edit-pro", style: "width: 220px !important;" %>
  </div>

  <div class="card-table">
    <table class="data-table">
      <thead>
        <tr>
          <th class="col-category">CATEGORIA / TIPO</th>
          <th class="col-sla-fixed">PRAZO ESTIMADO</th>
          <th class="col-actions-fixed">AÇÕES</th>
        </tr>
      </thead>
      <tbody>
        <% @ticket_types.each do |ticket_type| %>
          <tr>
            <td class="col-category">
              <div style="display: flex; align-items: center; gap: 10px;">
                <span style="color: #119DA4;">●</span>
                <strong style="color: #13505B;"><%= ticket_type.title %></strong>
              </div>
            </td>
            
            <td class="col-sla-fixed">
              <%= ticket_type.sla_hours %> horas
            </td>

            <td class="col-actions-fixed">
              <div class="action-buttons-row">
                <%= link_to "Ver", ticket_type, class: "btn-action-pill btn-details-pill" %>
                <%= link_to "Editar", edit_ticket_type_path(ticket_type), class: "btn-action-pill btn-details-pill" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>