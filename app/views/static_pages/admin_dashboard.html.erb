<div style="background-color: #f3f4f6; min-height: 100vh; padding: 50px 20px; font-family: 'Inter', system-ui, sans-serif;">
  
  <%# Container Centralizado do Dashboard %>
  <div style="max-width: 1000px; margin: 0 auto;">

    <%# Card de Boas-vindas %>
    <div style="background: white; padding: 40px; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e5e7eb; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h1 style="margin: 0; font-size: 2rem; color: #1f2937;">Olá, <%= current_user.email.split('@').first.capitalize %>! 💼</h1>
        <p style="color: #6b7280; font-size: 1.1rem; margin-top: 8px;">Bem-vinda ao seu Painel de Controle.</p>
      </div>
      <div style="font-size: 14px; color: #6b7280; text-align: right;">
        <div style="font-weight: 700; color: #1f2937;"><%= current_user.email %></div>
        <div style="text-transform: uppercase;"><%= current_user.role %></div>
        <%= button_to 'Encerrar Sessão', destroy_user_session_path, method: :delete, style: "background: none; border: none; color: #5b21b6; padding: 0; cursor: pointer; font-weight: 600; margin-top: 10px;" %>
      </div>
    </div>

  <%# Grid de 6 cards (3 por linha em telas grandes) %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px;">
    
    <%# 1. BLOCOS (O que faltava!) %>
    <div class="card-base" style="text-align: center; padding: 25px; transition: transform 0.2s;">
      <div style="font-size: 2.5rem; margin-bottom: 15px;">🏢</div>
      <h3 style="margin: 0 0 10px 0; font-size: 1.2rem; color: #1e293b;">Blocos</h3>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 20px;">Gerencie os prédios e estruturas do condomínio.</p>
      <%= link_to "Gerenciar Blocos", blocks_path, class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>
    </div>

    <%# 2. UNIDADES %>
    <div class="card-base" style="text-align: center; padding: 25px;">
      <div style="font-size: 2.5rem; margin-bottom: 15px;">🚪</div>
      <h3 style="margin: 0 0 10px 0; font-size: 1.2rem; color: #1e293b;">Unidades</h3>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 20px;">Lista geral de todos os apartamentos e salas.</p>
      <%= link_to "Ver Unidades", units_path, class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>
    </div>

    <%# 3. VINCULAR %>
    <div class="card-base" style="text-align: center; padding: 25px;">
      <div style="font-size: 2.5rem; margin-bottom: 15px;">🔗</div>
      <h3 style="margin: 0 0 10px 0; font-size: 1.2rem; color: #1e293b;">Vincular</h3>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 20px;">Associe moradores às suas respectivas unidades.</p>
      <%= link_to "Realizar Vínculo", user_units_path, class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>
    </div>

    <%# 4. CHAMADOS %>
    <div class="card-base" style="text-align: center; padding: 25px;">
      <div style="font-size: 2.5rem; margin-bottom: 15px;">🎫</div>
      <h3 style="margin: 0 0 10px 0; font-size: 1.2rem; color: #1e293b;">Chamados</h3>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 20px;">Acompanhe e resolva as solicitações pendentes.</p>
      <%= link_to "Abrir Chamados", tickets_path, class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>
    </div>

    <%# 5. TIPOS / SLA %>
    <div class="card-base" style="text-align: center; padding: 25px;">
      <div style="font-size: 2.5rem; margin-bottom: 15px;">⏱️</div>
      <h3 style="margin: 0 0 10px 0; font-size: 1.2rem; color: #1e293b;">Tipos/SLA</h3>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 20px;">Defina prazos e categorias de atendimento.</p>
      <%= link_to "Configurar SLA", ticket_types_path, class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>
    </div>

    <%# 6. STATUS %>
    <div class="card-base" style="text-align: center; padding: 25px;">
      <div style="font-size: 2.5rem; margin-bottom: 15px;">🛠️</div>
      <h3 style="margin: 0 0 10px 0; font-size: 1.2rem; color: #1e293b;">Status</h3>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 20px;">Personalize as etapas do fluxo de trabalho.</p>
      <%= link_to "Editar Status", statuses_path, class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>
    </div>

  </div>
</div>  

    <%# Rodapé do Dashboard %>
    <div style="text-align: center; margin-top: 50px; color: #9ca3af; font-size: 12px;">
      CondomínioPro © <%= Time.now.year %> - Sistema de Gestão Integrada
    </div>

  </div>
</div>